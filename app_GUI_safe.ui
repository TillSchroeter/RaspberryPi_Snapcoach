  <property name="styleSheet">
   <string notr="true">/* Macht den Hintergrund der einzelnen Tab-Seiten transparent, 
   damit der Hintergrund des QMainWindow durchscheint */
QTabWidget &gt; QWidget {
    background-color: transparent;
}

/* Design der Tab-Leiste */
QTabBar::tab {
    background: #333333;
    color: #aaaaaa;
    padding: 12px 20px;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    margin-right: 2px;
    min-width: 150px;
}

/* Der aktive Tab */
QTabBar::tab:selected {
    background: #0078d7;
    color: white;
    font-weight: bold;
}

/* Hover-Effekt für Tabs */
QTabBar::tab:hover:!selected {
    background: #444444;
}

/* Buttons modernisieren */
QPushButton {
    background-color: #0078d7;
    color: white;
    border-radius: 6px;
    font-size: 15px;
    font-weight: bold;
    padding: 10px 20px;
    border: none;
}

QPushButton:hover {
    background-color: #1e90ff;
}

QPushButton:pressed {
    background-color: #005a9e;
}

/* Labels (Text) hell machen, damit man sie auf dunklem Grund sieht */
QLabel {
    color: white;
    font-size: 14px;
}

/* Da Buttons oft ein eigenes Design haben, definiere es dort sicherheitshalber mit: */
QPushButton {
    color: #000000; 
}

QLabel {
    color: #000000;
}

QRadioButton {
    spacing: 8px; /* Abstand zwischen Kreis und Text */
    font-size: 16px;
    color: #333333; /* Textfarbe */
}

/* Der äußere Kreis */
QRadioButton::indicator {
    width: 20px;
    height: 20px;
    border-radius: 11px; /* Macht es rund */
    border: 2px solid #0078d7; /* Blauer Rand */
    background-color: white;
}

/* Wenn die Maus drüber schwebt */
QRadioButton::indicator:hover {
    background-color: #e6f2ff;
}

/* Wenn der Button ausgewählt ist (Der Punkt in der Mitte) */
QRadioButton::indicator:checked {
    background-color: #0078d7; /* Füllt den Kreis blau aus */
    border: 4px solid white;    /* Erzeugt einen weißen Ring-Effekt */
}

/* Für auswhl boxen */
QComboBox {
    background-color: white;
    color: black;
    border: 1px solid #ced4da;
    border-radius: 4px;
    padding: 2px;
	font-size: 9pt;
}

/* Für dauer frequenz box */
QDoubleSpinBox {
	font-size: 9pt;
}
QSpinBox {
	font-size: 9pt;
}


/* Die gesamte Tabelle */
QTableWidget {
    background-color: #ffffff;
    gridline-color: #d1d1d1;
    border: none; /* Entfernt den blauen Außenrahmen */
    font-family: &quot;Arial&quot;;
    font-size: 10pt;
}

/* Der Header oben (Horizontal) und links (Vertical) */
QHeaderView::section {
    background-color: #5dade2;
    color: white;
    padding: 4px;
    font-weight: bold;
    border: 1px solid #5dade2; /* Feine weiße Trennlinie zwischen den Headern */
}

/* Die kleine Ecke oben links, wo sich beide Header treffen */
QTableCornerButton::section {
    background-color: #f9f9f9;
    border: 1px solid #f9f9f9;
}

/* Styling der ausgewählten Zellen */
QTableWidget::item:selected {
    background-color: #aed6f1;
    color: black;
}</string>
  </property>
