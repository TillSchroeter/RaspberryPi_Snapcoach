/* Der normale Zustand */
QPushButton {
    background-color: #0078d7;
    border-radius: 8px;
    padding: 10px;
    color: white;
	font-size: 20px;
	font-weight: bold;/* /* Wenn es fett gedruckt sein soll */
}

/* Der Zustand, während man draufdrückt */
QPushButton:pressed {
    background-color: #005a9e; /* Dunkleres Blau */
    border: 2px solid #ffffff;  /* Ein weißer Rahmen erscheint */
    padding-top: 12px;         /* Verschiebt den Text leicht nach unten */
    padding-left: 12px;        /* Erzeugt einen &quot;Eindrück-Effekt&quot; */
}

QPushButton:hover {
    background-color: #1e90ff; /* Etwas helleres Blau beim Drüberfahren */
}</string>
