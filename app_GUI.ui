  <property name="styleSheet">
   <string notr="true">/* Der Haupt-Hintergrund für das gesamte Fenster */
QMainWindow, QWidget#centralwidget, QTabWidget::pane {
    background-color: #1e1e1e; /* Ein etwas edleres, dunkleres Grau */
    border: none;
}

/* Macht den Hintergrund der einzelnen Tab-Seiten transparent, 
   damit der Hintergrund des QMainWindow durchscheint */
QTabWidget &gt; QWidget {
    background-color: transparent;
}

/* Design der Tab-Leiste */
QTabBar::tab {
    background: #333333;
    color: #aaaaaa;
    padding: 12px 20px;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    margin-right: 2px;
    min-width: 120px;
}

/* Der aktive Tab */
QTabBar::tab:selected {
    background: #0078d7;
    color: white;
    font-weight: bold;
}

/* Hover-Effekt für Tabs */
QTabBar::tab:hover:!selected {
    background: #444444;
}

/* Buttons modernisieren */
QPushButton {
    background-color: #0078d7;
    color: white;
    border-radius: 6px;
    font-size: 15px;
    font-weight: bold;
    padding: 10px 20px;
    border: none;
}

QPushButton:hover {
    background-color: #1e90ff;
}

QPushButton:pressed {
    background-color: #005a9e;
}

/* Labels (Text) hell machen, damit man sie auf dunklem Grund sieht */
QLabel {
    color: white;
    font-size: 14px;
}

/* Da Buttons oft ein eigenes Design haben, definiere es dort sicherheitshalber mit: */
QPushButton {
    color: #000000; 
}

QLabel {
    color: #000000;
}

QRadioButton {
    spacing: 8px; /* Abstand zwischen Kreis und Text */
    font-size: 16px;
    color: #333333; /* Textfarbe */
}

/* Der äußere Kreis */
QRadioButton::indicator {
    width: 20px;
    height: 20px;
    border-radius: 11px; /* Macht es rund */
    border: 2px solid #0078d7; /* Blauer Rand */
    background-color: white;
}

/* Wenn die Maus drüber schwebt */
QRadioButton::indicator:hover {
    background-color: #e6f2ff;
}

/* Wenn der Button ausgewählt ist (Der Punkt in der Mitte) */
QRadioButton::indicator:checked {
    background-color: #0078d7; /* Füllt den Kreis blau aus */
    border: 4px solid white;    /* Erzeugt einen weißen Ring-Effekt */
}</string>
